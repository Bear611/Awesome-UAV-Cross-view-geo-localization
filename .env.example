# Do not commit real API keys.
DEEPSEEK_API_KEY=your_deepseek_key
MINIMAX_API_KEY=your_minimax_key
SEMANTIC_SCHOLAR_API_KEY=optional_semantic_scholar_key

# Optional. OpenAlex does not need an API key, but a mailto value is recommended by OpenAlex etiquette.
OPENALEX_MAILTO=your_email@example.com

DEEPSEEK_MODEL=deepseek-chat
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_PDF_CHAR_LIMIT=120000
MINIMAX_PDF_MAX_PAGES=80
MINIMAX_PDF_MAX_BYTES=104857600
MINIMAX_PDF_LANDING_MAX_BYTES=3145728
MINIMAX_PDF_MAX_CANDIDATES=16
MINIMAX_TABLE_CHAR_LIMIT=30000
UAV_CVGL_PDF_CACHE_DIR=data/pdf_cache

# MiniMax-M3 long-context request controls
MINIMAX_REQUEST_TIMEOUT=180
MINIMAX_REQUEST_RETRIES=3


# Do not commit real API keys.
DEEPSEEK_API_KEY=your_deepseek_key
MINIMAX_API_KEY=your_minimax_key
SEMANTIC_SCHOLAR_API_KEY=optional_semantic_scholar_key

# Optional. OpenAlex does not need an API key, but a mailto value is recommended by OpenAlex etiquette.
OPENALEX_MAILTO=your_email@example.com

DEEPSEEK_MODEL=deepseek-chat
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_PDF_CHAR_LIMIT=120000
MINIMAX_PDF_MAX_PAGES=80
MINIMAX_PDF_MAX_BYTES=104857600
MINIMAX_PDF_LANDING_MAX_BYTES=3145728
MINIMAX_PDF_MAX_CANDIDATES=16
MINIMAX_TABLE_CHAR_LIMIT=30000
UAV_CVGL_PDF_CACHE_DIR=data/pdf_cache

# MiniMax-M3 long-context request controls
MINIMAX_REQUEST_TIMEOUT=180
MINIMAX_REQUEST_RETRIES=3

# Leaderboard full-text discovery uses MiniMax-M3 built-in search by default.
LEADERBOARD_DISCOVERY_TIMEOUT=300
LEADERBOARD_URL_TIMEOUT=30
LEADERBOARD_DISCOVERY_PROGRESS=25
LEADERBOARD_REVIEW_PROGRESS=25
# Skip unstable IEEE staging PDF endpoints during non-browser HTTP discovery.
LEADERBOARD_SKIP_IEEE_STAGING=1
# Optional overrides if the MiniMax API changes the built-in search tool schema.
# MINIMAX_SEARCH_TOOLS_JSON={"type":"web_search"}
# MINIMAX_SEARCH_TOOL_VARIANTS_JSON=[[{"type":"web_search"}]]
# Optional fallback to local DuckDuckGo HTML search; MiniMax search is preferred.
LEADERBOARD_USE_LOCAL_SEARCH=0

# Optional visible-browser CARSI/CAS login support. Do not commit profile or cookie files.
UAV_CVGL_BROWSER_PROFILE=D:\agent_browser_profile
UAV_CVGL_COOKIE_FILE=C:\tmp\uav_cvgl_cookies.txt
UAV_CVGL_DOWNLOAD_DIR=C:\tmp\uav_cvgl_downloads


# Copy this file to .env.local only for local testing.
# Do NOT commit real API keys.
DEEPSEEK_API_KEY=replace_with_your_deepseek_key
MINIMAX_API_KEY=replace_with_your_minimax_key
DEEPSEEK_MODEL=deepseek-chat
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Optional, but useful to reduce Semantic Scholar rate limit issues.
SEMANTIC_SCHOLAR_API_KEY=
